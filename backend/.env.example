# ── Crisis Monitor Backend ── Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it's already in .gitignore.

# LLM provider (OpenCode Go API)
OPENCODE_GO_API_KEY=sk-your-key-here

# External data APIs
NEWS_API_KEY=your-newsapi-key
FRED_API_KEY=your-fred-key

# Auth — trigger endpoint protection (Layer 3)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
CRISIS_TRIGGER_TOKEN=replace-with-32-random-chars

# LLM model identifier (used in health endpoint metadata)
LLM_MODEL=mimo-v2.5
